# ===== חובה =====
# Railway מזריק את זה אוטומטית כשמוסיפים Postgres לפרויקט — לא צריך למלא ידנית.
DATABASE_URL=

# ===== מומלץ =====
# הכתובת הציבורית של האפליקציה שלך ב-Railway (מופיע ב-Settings > Domains)
APP_URL=https://your-app.up.railway.app

# מספר הוואטסאפ שלך לקבלת התראת "התנתקות" (בפורמט הזה, בלי +)
NOTIFY_JID=972501234567@s.whatsapp.net

# ===== אופציונלי =====
# התראות מייל (Gmail App Password — לא הסיסמה הרגילה)
ALERT_EMAIL=
GMAIL_USER=
GMAIL_PASS=

# גיבוי לגוגל שיטס (אופציונלי לגמרי — משאירים ריק אם לא בשימוש)
SHEET_ID=
GOOGLE_CREDENTIALS=
